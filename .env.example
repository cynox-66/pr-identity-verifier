# GitHub App Webhook Configuration
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App Authentication Token
GITHUB_TOKEN=ghp_your_token_here

# Server Configuration
PORT=3000
NODE_ENV=development

# ── Verification Behaviour ────────────────────────────────────────────
# Report results as a GitHub Check Run (appears on PR Checks tab)
ENABLE_CHECK_RUNS=false

# Post a PR comment with structured verification results
ENABLE_PR_COMMENTS=true

# Require cryptographic signatures on all commits (HARD_FAIL vs SOFT_FAIL)
REQUIRE_COMMIT_SIGNATURES=false

# Maximum commits to verify per PR (safety bound)
MAX_COMMITS_PER_PR=250

# ── DID Configuration ────────────────────────────────────────────────
# Domain used in mock did:web identifiers
DID_DOMAIN=example.com

# DID of the mock credential issuer
CREDENTIAL_ISSUER=did:web:issuer.example

# Comma-separated list of trusted issuer DIDs
TRUSTED_ISSUERS=did:web:issuer.example

# ── GitHub App Configuration ──────────────────────────────────────────
# Production: Use GitHub App authentication (JWT + installation tokens)
# Development: Use a PAT as a fallback
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=ghp_your_token_here

# GitHub App settings (production — see src/auth/githubApp.ts)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem

# Server Configuration
PORT=3000
NODE_ENV=development

# ── Verification Mode ────────────────────────────────────────────────
# 'simulated'  — SHA-256 hash comparison (deterministic, default)
# 'real_crypto' — Real Ed25519 via @noble/ed25519
VERIFICATION_MODE=simulated

# ── Verification Behaviour ────────────────────────────────────────────
# Report results as a GitHub Check Run (appears on PR Checks tab)
ENABLE_CHECK_RUNS=false

# Post a PR comment with structured verification results
ENABLE_PR_COMMENTS=true

# Require cryptographic signatures on all commits (HARD_FAIL vs SOFT_FAIL)
REQUIRE_COMMIT_SIGNATURES=false

# Maximum commits to verify per PR (safety bound)
MAX_COMMITS_PER_PR=250

# ── DID Configuration ────────────────────────────────────────────────
# Domain used in mock did:web identifiers
DID_DOMAIN=example.com

# DID of the mock credential issuer
CREDENTIAL_ISSUER=did:web:issuer.example

# Comma-separated list of trusted issuer DIDs
TRUSTED_ISSUERS=did:web:issuer.example

# ── Security Tuning ──────────────────────────────────────────────────
# Maximum entries in replay protection registry (prevents memory leak)
REPLAY_REGISTRY_MAX_SIZE=10000

# TTL for replay registry entries in milliseconds (default: 1 hour)
REPLAY_REGISTRY_TTL_MS=3600000

# TTL for DID Document cache entries in milliseconds (default: 5 minutes)
DID_CACHE_TTL_MS=300000

# Maximum entries in DID Document cache
DID_CACHE_MAX_SIZE=1000

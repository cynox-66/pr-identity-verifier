{
  "name": "github-identity-verifier",
  "version": "1.0.0",
  "description": "Deterministic DID-based identity verification pipeline for GitHub PRs — commit-level signature verification with cryptographic proof",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:adversarial": "jest tests/adversarial",
    "test:concurrency": "jest tests/concurrency",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --forceExit"
  },
  "keywords": [
    "github",
    "webhook",
    "identity-verification",
    "decentralized-identity",
    "did",
    "verifiable-credentials",
    "commit-signatures",
    "cryptographic-verification"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@octokit/app": "^15.1.2",
    "@octokit/rest": "^20.0.2",
    "@octokit/webhooks": "^13.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
